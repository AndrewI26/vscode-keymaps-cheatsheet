{
  "name": "keybindings-cheatsheet",
  "displayName": "Keybindings Cheatsheet - Instantly view your VS Code keyboard shortcuts",
  "description": "Turns a keybindings file into a clean cheatsheet!",
  "keywords": [
    "keybindings",
    "nvim",
    "cheatsheet",
    "keybindings",
    "keyboard shortcuts",
    "cheatsheet",
    "shortcut cheatsheet",
    "keymap",
    "keymap viewer",
    "keybindings viewer",
    "vim",
    "vscode vim",
    "vim keybindings",
    "vim cheatsheet",
    "neovim",
    "neovim keybindings",
    "productivity",
    "developer tools",
    "workflow",
    "navigation",
    "keyboard driven",
    "shortcuts manager",
    "remember shortcuts",
    "shortcut reference",
    "keybindings helper",
    "keyboard reference",
    "shortcut guide"
  ],
  "publisher": "andrewi",
  "repository": {
    "type": "git",
    "url": "https://github.com/AndrewI26/vscode-keymaps-cheatsheet"
  },
  "icon": "images/icon.png",
  "version": "1.1.2",
  "homepage": "https://github.com/AndrewI26/vscode-keymaps-cheatsheet#readme",
  "engines": {
    "vscode": "^1.60.0"
  },
  "activationEvents": [
    "onCommand:keybindingsCheatsheet.showCheatsheet"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "keybindingsCheatsheet.showCheatsheet",
        "title": "Keybindings Cheatsheet: Show"
      }
    ]
  },
  "scripts": {
    "compile": "npm run check-types && node esbuild.js",
    "check-types": "tsc --noEmit",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "vscode:prepublish": "npm run package",
    "package": "npm run check-types && node esbuild.js --production"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/vscode": "^1.60.0",
    "copyfiles": "^2.4.1",
    "esbuild-handlebars": "^1.1.0",
    "esbuild-plugin-handlebars": "^1.0.3",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.7.4",
    "typescript": "^4.4.3"
  },
  "dependencies": {
    "esbuild": "^0.27.2",
    "handlebars": "^4.7.8",
    "jsonc-parser": "^3.3.1"
  }
}
